# Copy this file to .env and fill in the values before running in production.

# ── Server ────────────────────────────────────────────────────────────────────
# The host/port the Fastify server binds to.
# Use 127.0.0.1 when running behind a reverse proxy (nginx / Caddy).
# Use 0.0.0.0 only if you want direct external access (not recommended).
HOST=127.0.0.1
PORT=3000

# ── Session secret ────────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. Keep this secret — anyone who has it can forge sessions.
SESSION_SECRET=change_me_to_a_random_32_plus_char_string

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite database file. The directory will be created if it does not exist.
# Back up this file to back up all data.
DB_PATH=./data/tasks.db

# ── Misc ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
